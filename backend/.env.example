# Copy this file to .env and fill in your values
# The backend works without any API keys using fixture-based fallbacks

# Anthropic Claude API key (optional — fallback explanations used if absent)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Force fixture-based mode regardless of live API availability (true/false)
USE_FIXTURES=true

# ESMFold public API (optional — fixture fallback used if unavailable)
ESMFOLD_API_URL=https://api.esmatlas.com/foldSequence/v1/pdb/

# SQLite database file path (relative to backend directory)
DB_PATH=vaxagent.db

# CORS origin for frontend (adjust if serving from a different port)
CORS_ORIGIN=http://localhost:8080
