# Copy this file to .env and fill in your values
# The backend works without any API keys using fixture-based fallbacks

# Anthropic Claude API key (optional — fallback explanations used if absent)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Force fixture-based mode regardless of live API availability (true/false)
# Set to false to enable live pVACseq Docker runs
USE_FIXTURES=true

# ESMFold public API (optional — fixture fallback used if unavailable)
ESMFOLD_API_URL=https://api.esmatlas.com/foldSequence/v1/pdb/

# SQLite database file path (relative to backend directory)
DB_PATH=vaxagent.db

# CORS origin for frontend (adjust if serving from a different port)
CORS_ORIGIN=http://localhost:8080

# VEP cache directory on the host machine (required for live pVACseq)
# Download with: docker run --rm -v $HOME/.vep:/opt/vep/.vep griffithlab/pvactools:latest
#   vep_install -a cf -s homo_sapiens -y GRCh37 -c /opt/vep/.vep --CONVERT
VEP_CACHE_DIR=/path/to/vep_cache

# Reference genome assembly used in the VCF (GRCh37 or GRCh38)
VEP_ASSEMBLY=GRCh37

# Timeout in seconds for the VEP annotation Docker step (default: 7200 = 2 hours)
VEP_TIMEOUT=7200

# Timeout in seconds for the pVACseq Docker step (default: 14400 = 4 hours)
# Large VCFs (>500 variants) can take 3-5 hours; set higher if needed
PVACSEQ_TIMEOUT=14400
